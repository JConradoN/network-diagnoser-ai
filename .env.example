# Exemplo de variáveis de ambiente para Network Diagnoser AI
# Copie este arquivo para .env e ajuste conforme necessário

# Sub-rede alvo (CIDR)
ND_SUBNET=192.168.88.0/24
# Interface de rede (ex: eth0, wlan0)
ND_INTERFACE=wlan0
# Comunidade SNMP
ND_SNMP_COMMUNITY=public
# Timeout SNMP (segundos)
ND_SNMP_TIMEOUT=2
# Habilitar SNMP
ND_SNMP_ENABLED=true
# Quantidade de pings por host
ND_PING_COUNT=4
# Habilitar testes de latência/jitter
ND_LATENCY_ENABLED=true
# Domínio para teste DNS
ND_DNS_TEST_DOMAIN=google.com
# Habilitar teste DNS
ND_DNS_ENABLED=true
# Alvo para traceroute
ND_TRACEROUTE_TARGET=8.8.8.8
# Habilitar análise de rota
ND_ROUTE_ENABLED=true
# Timeout para DHCP discovery
ND_DHCP_DISCOVERY_TIMEOUT=4
# Habilitar detector DHCP
ND_DHCP_ENABLED=true
# Habilitar descoberta mDNS
ND_MDNS_ENABLED=true
# Habilitar descoberta SSDP
ND_SSDP_ENABLED=true
# Habilitar scan de portas
ND_PORT_SCAN_ENABLED=true
# Portas para scan (CSV)
ND_PORT_SCAN_PORTS=22,53,67,68,80,443
# Estimativa de hosts ativos
ND_EXPECTED_ACTIVE_HOSTS=30
# CORS para API (CSV de URLs)
ND_API_CORS_ORIGINS=http://localhost:5173
# Chave Gemini API (opcional)
GEMINI_API_KEY=
# Modelo Gemini (opcional)
GEMINI_MODEL=gemini-2.5-flash
